# 90Minutes — Environment Variables
# Copy this file to .env and fill in your values after cdk deploy

# WebSocket URL (from CDK output)
EXPO_PUBLIC_WS_URL=wss://XXXXXXXX.execute-api.us-east-1.amazonaws.com/prod

# Cognito (from CDK output)
EXPO_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXX
EXPO_PUBLIC_CLIENT_ID=XXXXXXXXXXXXXXXXXX

# AWS Region (sandbox restriction: us-east-1 only)
EXPO_PUBLIC_API_REGION=us-east-1
